PORT=3000
NODE_ENV=development

# JWT user: doit etre la meme valeur que USER_JWT_SECRET de auth-service
USER_JWT_SECRET=replace-with-user-jwt-secret

# URLs des services appeles par le gateway
AUTH_SERVICE_URL=http://localhost:3001
TEAM_SERVICE_URL=http://localhost:3002

# Active l'introspection GraphQL en dev
ENABLE_GRAPHQL_INTROSPECTION=true

# Pas de SERVICE_JWT_SECRET ni AUTH_SERVICE_CLIENT_* : JWT utilisateur uniquement ; pas d'emission de service-token dans l'impl actuelle
