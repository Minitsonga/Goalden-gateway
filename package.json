{
  "name": "goalden-api-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "GraphQL API gateway for Goalden microservices.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.11.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.30",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
